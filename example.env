PROJECT_ID=your-gcp-project-id
LOCATION=global
COLLECTION=default_collection
# GE_APP_ID is your Gemini Enterprise app ID — see "Finding your Engine ID" in README.md
GE_APP_ID=your-engine-id
ASSISTANT=default_assistant
BASE_URL=discoveryengine.googleapis.com
# LLM(s) for code generation. Allowed: gemini-3.1-pro-preview, gemini-3.5-flash
# (gemini-3.1-pro-preview is served from the `global` location only).
MODEL=gemini-3.5-flash
