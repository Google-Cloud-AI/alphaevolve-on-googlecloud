# Zillow Prize Kaggle Competition — AlphaEvolve Example

# GCP project
PROJECT_ID=your-gcp-project-id

# AlphaEvolve API settings
LOCATION=global
COLLECTION=default_collection
# GE_APP_ID is your Gemini Enterprise app ID — see "Finding your Engine ID" in the root README.md
GE_APP_ID=your-engine-id
ASSISTANT=default_assistant
BASE_URL=discoveryengine.googleapis.com

# Cloud Run evaluator URL (fill after deploying with Cloud Build)
EVALUATOR_URL=https://alphaevolve-kaggle-evaluator-xxxxx-uc.a.run.app

# Model settings — LLM(s) used to generate and evolve code.
# Allowed: gemini-2.5-flash, gemini-2.5-pro, gemini-3-flash-preview,
#          gemini-3-pro-preview, gemini-3.5-flash
MODEL=gemini-2.5-flash

# Experiment settings
MAX_PROGRAMS_GENERATED=50
MAX_PROGRAMS_EVALUATED=50
CONCURRENCY=4
