# LLM Fine-Tuning Hyperparameter Optimization — AlphaEvolve Example
# Copy to .env and fill in the values before running:
#   cp example.env .env

# --------------------------------------------------------------------------
# GCP Project
# --------------------------------------------------------------------------
PROJECT_ID=your-gcp-project-id
REGION=us-central1
SERVICE_ACCOUNT_EMAIL=your-sa@your-gcp-project-id.iam.gserviceaccount.com

# --------------------------------------------------------------------------
# AlphaEvolve API
# --------------------------------------------------------------------------
LOCATION=global
COLLECTION=default_collection
# GE_APP_ID is your Gemini Enterprise app ID — see "Finding your Engine ID" in the root README.md
GE_APP_ID=your-engine-id
ASSISTANT=default_assistant
BASE_URL=discoveryengine.googleapis.com

# --------------------------------------------------------------------------
# Model
# --------------------------------------------------------------------------
# Available: gemini-3.1-pro-preview, gemini-3.5-flash
# (gemini-3.1-pro-preview is served from the `global` location only).
MODEL=gemini-3.5-flash

# --------------------------------------------------------------------------
# Experiment
# --------------------------------------------------------------------------
MAX_PROGRAMS_GENERATED=20
MAX_PROGRAMS_EVALUATED=20
CONCURRENCY=2

# --------------------------------------------------------------------------
# Remote Evaluator (GKE gateway)
# --------------------------------------------------------------------------
# After deploy: kubectl port-forward svc/gateway -n alphaevolve 8080:80
EVALUATOR_URL=http://localhost:8080/evaluate

# --------------------------------------------------------------------------
# HuggingFace (for gated Gemma 4 model access)
# --------------------------------------------------------------------------
HF_TOKEN=
