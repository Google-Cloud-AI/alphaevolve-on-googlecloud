# Circle Packing — AlphaEvolve Example
# Copy to .env and fill in the values before running:
#   cp example.env .env

# --------------------------------------------------------------------------
# GCP Project
# --------------------------------------------------------------------------
PROJECT_ID=your-gcp-project-id

# --------------------------------------------------------------------------
# AlphaEvolve API
# --------------------------------------------------------------------------
LOCATION=global
COLLECTION=default_collection
# GE_APP_ID is your Gemini Enterprise app ID — see "Finding your Engine ID" in the root README.md
GE_APP_ID=your-engine-id
ASSISTANT=default_assistant
BASE_URL=discoveryengine.googleapis.com

# --------------------------------------------------------------------------
# Model (weighted mixture; relative weights are normalized server-side)
# --------------------------------------------------------------------------
# Allowed: gemini-3.1-pro-preview, gemini-3.5-flash
# (gemini-3.1-pro-preview is served from the `global` location only).
MODEL_1=gemini-3.5-flash
MODEL_1_WEIGHT=0.7
MODEL_2=gemini-3.1-pro-preview
MODEL_2_WEIGHT=0.3

# --------------------------------------------------------------------------
# Experiment
# --------------------------------------------------------------------------
MAX_PROGRAMS_GENERATED=10
MAX_PROGRAMS_EVALUATED=10
CONCURRENCY=4
WORKER_CONCURRENCY=4
PARALLEL_EVALUATION=False

